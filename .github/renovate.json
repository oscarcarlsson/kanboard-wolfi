{
  "extends": ["config:base"],
  "packageRules": [
    {
      "description": "Uppdate VERSION with the latest Kanboard-release",
      "packageNames": ["kanboard"],
      "enabled": true,
      "datasource": "github-releases",
      "depType": "pin",
      "registryUrls": ["https://github.com/kanboard/kanboard"],
      "extractVersion": {
	"fileMatch": ["^VERSION$"],
	"matchStrings": ["^(?<version>v.*)$"]
      },
      "updateTypes": ["minor", "patch", "major"]
    }
  ]
}

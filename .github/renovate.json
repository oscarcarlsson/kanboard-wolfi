{
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "^VERSION$"
      ],
      "matchStrings": [
        "^(?<currentValue>v?\\d+\\.\\d+\\.\\d+)$"
      ],
      "currentValueTemplate": "{{ currentValue }}",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kanboard/kanboard",
      "versioningTemplate": "semver"
    }
  ]
}
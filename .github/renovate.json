{
  "extends": [
    "config:base"
  ],
  "regexManagers": [
    {
      "fileMatch": [
        "^VERSION$"
      ],
      "matchStrings": [
        "^(?<currentValue>v?\\d+\\.\\d+\\.\\d+)$"
      ],
      "currentValueTemplate": "{{ currentValue }}",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kanboard/kanboard",
      "versioningTemplate": "semver"
    }
  ]
}